{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Simple API",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "icon": "book-open-cover",
          "href": "https://mintlify.com/docs"
        },
        {
          "anchor": "Blog",
          "icon": "newspaper",
          "href": "https://mintlify.com/blog"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "installation"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/basic-usage",
              "guides/error-handling",
              "guides/examples"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/overview"
            ]
          },
          {
            "group": "Clients",
            "pages": [
              "api-reference/clients/list",
              "api-reference/clients/create",
              "api-reference/clients/get",
              "api-reference/clients/update",
              "api-reference/clients/delete"
            ]
          },
          {
            "group": "Products",
            "pages": [
              "api-reference/products/list",
              "api-reference/products/create",
              "api-reference/products/get",
              "api-reference/products/update",
              "api-reference/products/delete"
            ]
          },
          {
            "group": "Categories",
            "pages": [
              "api-reference/categories/list",
              "api-reference/categories/create",
              "api-reference/categories/get",
              "api-reference/categories/update",
              "api-reference/categories/delete"
            ]
          },
          {
            "group": "Services",
            "pages": [
              "api-reference/services/list",
              "api-reference/services/create",
              "api-reference/services/get",
              "api-reference/services/update",
              "api-reference/services/delete"
            ]
          },
          {
            "group": "Accounts",
            "pages": [
              "api-reference/accounts/list",
              "api-reference/accounts/create",
              "api-reference/accounts/get",
              "api-reference/accounts/update",
              "api-reference/accounts/delete"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hi@mintlify.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  }
}
